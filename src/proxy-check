#!/usr/bin/env bash
#
# @file      proxy-check
# @author    eda Air_Code@outlook.com
# @version   2.1.0
# @date      2025-10-12
#
# @brief     一个用于验证终端代理的脚本。
#
# @description
#   该脚本通过环境变量检测代理设置，并使用 curl 命令尝试连接一个
#   指定的 URL 来判断代理的有效性。它支持自定义目标 URL 和超时时间。
#
# @usage
#   proxy-check [-u URL] [-t TIMEOUT] [-h]
#
# @requires  bash, curl
#

# ------------------------------------------------------------------------------
# Default configuration
DEFAULT_URL="https://www.google.com"
DEFAULT_TIMEOUT=10

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ------------------------------------------------------------------------------
# Exit immediately if a command exits with a non-zero status.
set -e
# Treat unset variables as an error when substituting.
set -u
# Pipes return the exit status of the last command to exit with a non-zero status.
set -o pipefail

# ------------------------------------------------------------------------------
usage() {
  echo -e "${YELLOW}Usage: $(basename "$0") [-u URL] [-t TIMEOUT] [-h]${NC}"
  echo "  A script to verify if the current terminal proxy is working."
  echo
  echo "  Options:"
  echo "    -u URL      Specify the URL to test against. (Default: ${DEFAULT_URL})"
  echo "    -t TIMEOUT  Set the connection timeout in seconds. (Default: ${DEFAULT_TIMEOUT})"
  echo "    -h          Display this help message."
  exit 0
}

# ------------------------------------------------------------------------------
main() {
  local test_url="${DEFAULT_URL}"
  local timeout="${DEFAULT_TIMEOUT}"

  # Principle 5: Parse command-line arguments
  while getopts "u:t:h" opt; do
    case ${opt} in
    u) test_url="${OPTARG}" ;;
    t) timeout="${OPTARG}" ;;
    h) usage ;;
    \?)
      echo "Invalid option: -${OPTARG}" >&2
      exit 1
      ;;
    esac
  done

  # Check for dependencies
  if ! command -v curl &>/dev/null; then
    echo -e "${RED}Error: 'curl' is required but not installed. Aborting.${NC}" >&2
    exit 1
  fi

  echo -e "${BLUE}--- Proxy Check Utility ---${NC}"

  # Check for proxy environment variables
  local proxy_server="${https_proxy:-${HTTPS_PROXY:-${http_proxy:-${HTTP_PROXY:-""}}}}"
  if [ -z "${proxy_server}" ]; then
    echo -e "${YELLOW}Warning: No proxy environment variables (http_proxy, https_proxy) are set.${NC}" >&2
    exit 1
  fi
  echo -e "Detected proxy: ${GREEN}${proxy_server}${NC}"

  # Perform the test
  echo "Attempting to connect to '${test_url}' via proxy..."
  echo "Timeout set to ${timeout} seconds."

  local http_status
  http_status=$(curl --insecure -s -I -L -o /dev/null -w '%{http_code}' \
    --connect-timeout "${timeout}" \
    --proxy "${proxy_server}" \
    "${test_url}")

  # Analyze the result
  if [[ "${http_status}" -ge 200 && "${http_status}" -lt 400 ]]; then
    echo -e "\n${GREEN}✔ SUCCESS: Proxy is working correctly.${NC}"
    echo "Received HTTP status: ${http_status}"
  else
    echo -e "\n${RED}✖ FAILURE: Proxy seems to be misconfigured or down.${NC}" >&2
    echo "Received HTTP status: ${http_status}. A status of 000 often indicates a timeout or DNS failure." >&2
    exit 1
  fi

  echo -e "${BLUE}---------------------------${NC}"
}

# Run the main function
main "$@"
